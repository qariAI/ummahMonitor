# ── UmmahMonitor environment ─────────────────────────────────────────────
# Copy to .env.local and fill in. All keys are optional in dev: the app runs
# with SQLite, a stubbed donation checkout, and a static AI-brief fallback
# when the corresponding secret is absent.

# Data layer — SQLite by default; point at Postgres/MySQL for production.
DATABASE_URL="file:./dev.db"

# Auth — 32+ char secret used to sign session cookies. REQUIRED in production.
# Generate: openssl rand -base64 32
SESSION_SECRET="dev-only-insecure-secret-change-me-0123456789"

# Publish threshold governing published/developing/withheld across the product.
# Configurable backend constant (README Design Tokens). Defaults to 70.
PUBLISH_THRESHOLD=70

# Payments — Stripe. When unset, "Give →" returns a stubbed dev checkout URL
# instead of hitting Stripe, so the flow is exercisable without keys.
STRIPE_SECRET_KEY=""
STRIPE_SUCCESS_URL="http://localhost:3000/donate/success"
STRIPE_CANCEL_URL="http://localhost:3000/donate/cancel"
# Signing secret for /api/webhooks/stripe. REQUIRED once STRIPE_SECRET_KEY is
# set — this is what proves a "payment completed" event actually came from
# Stripe rather than a spoofed client request. Get it via `stripe listen`
# (local dev) or the Stripe Dashboard webhook config (production).
STRIPE_WEBHOOK_SECRET=""

# LLM — Anthropic. When unset, the AI Situational Brief falls back to the
# event's static summary with a "Live analyst unavailable" note.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
