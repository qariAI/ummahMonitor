// UmmahMonitor data layer.
// Postgres in production (serverless hosts like Vercel don't persist files
// created during build, so SQLite doesn't work there).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  name       String  @id
  flag       String
  code       String
  lon        Float
  lat        Float
  score      Int
  trend      String // up | down | flat
  components String // JSON: { Safety, Humanitarian, Worship, Economy }
  events     Event[]
}

model Event {
  id          Int      @id @default(autoincrement())
  category    String
  title       String
  countryName String
  country     Country  @relation(fields: [countryName], references: [name])
  lat         Float
  lon         Float
  severity    String
  timestamp   DateTime
  what        String
  why         String
  status      String
  keywords    String // JSON array
  timeline    String // JSON array of { at, text }
  related     String // JSON array of event ids
  response    String? // JSON ResponseModule
  pending     Boolean  @default(false)
  conflicting Boolean  @default(false)
  // Optional confidence override; when null, derived from sources by the
  // shared confidence service (never stored, always recomputed).
  confidenceOverride Int?
  sources     Source[]
  savedBy     SavedEvent[]

  @@index([category])
  @@index([pending])
}

model Source {
  id       Int     @id @default(autoincrement())
  name     String
  verified Boolean @default(false)
  tier     String? // official | wire | relief | regional | community (inferred if null)
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId  Int

  @@index([eventId])
}

// Community/partner submissions awaiting human review.
model ModerationItem {
  id          Int      @id @default(autoincrement())
  category    String
  countryName String
  severity    String
  title       String
  submitter   String
  submittedAt DateTime @default(now())
  trustScore  Int // precomputed confidence for this submission (0-100)
  mediaCount  Int      @default(0)
  flagged     Boolean  @default(false)
  conflicting Boolean  @default(false)
  checks      String // JSON array of { label, detail, ok }
  aiVerdict   String
  body        String
  sources     String // JSON array of { name, verified, tier? }
  decision    String? // approved | rejected | flagged | null
  decidedAt   DateTime?
  decidedBy   String?

  @@index([decision])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
  donations    Donation[]

  // Authorization — "user" | "moderator" | "admin". Named distinctly from
  // the onboarding "role" field below (which is a job-title like Researcher/
  // Journalist, unrelated to permissions). Never settable via the public
  // signup/onboarding APIs; only changed directly in the DB or by an
  // existing admin through an internal tool.
  authRole   String  @default("user")

  // Onboarding preferences — collected in the /onboarding flow, applied to
  // the dashboard's default feed filters and (eventually) alert delivery.
  onboarded  Boolean @default(false)
  role       String?
  categories String? // JSON array of category keys
  regions    String? // JSON array of region keys (broad groups, e.g. "mena")
  followedCountries String? // JSON array of specific country names, e.g. ["Sudan","Palestine"]
  severity   String  @default("high") // all | medium | high | critical
  digest     String  @default("daily") // real-time | hourly | daily | weekly
  channels   String? // JSON: { inapp, email, whatsapp }

  savedEvents SavedEvent[]
}

// Server-side session persistence — opaque token stored hashed, matched to a
// signed httpOnly cookie.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

// A user bookmarking an event — the "Save events" feature. Deliberately a
// thin join table (no extra fields yet) so it's cheap to query in both
// directions: "did this user save this event" and "all events this user saved".
model SavedEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
}

model Donation {
  id             String   @id @default(cuid())
  org            String
  appeal         String
  amount         Int // minor units (cents)
  currency       String   @default("usd")
  eventId        Int?
  status         String // pending | completed | canceled
  provider       String // stripe | stub
  providerRef    String? // Stripe checkout session id
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  createdAt      DateTime @default(now())

  @@index([status])
}

// Cached AI-generated situational summaries — "scope" is either "global"
// (the daily Ummah-wide briefing) or a country name (a country-specific
// briefing). Cached rather than regenerated per page-load: this is the
// same cost-control gap flagged for /api/brief in the original launch
// audit, so briefings are generated at most once per REFRESH_INTERVAL and
// reused for every visitor in between.
model Briefing {
  id          String   @id @default(cuid())
  scope       String   // "global" | a Country.name
  bullets     String   // JSON array of strings
  readSeconds Int
  live        Boolean  // true if LLM-generated, false if fallback text
  generatedAt DateTime @default(now())

  @@index([scope, generatedAt])
}
